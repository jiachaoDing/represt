<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/quick_timer_notification_root"
    android:layout_width="match_parent"
    android:layout_height="48dp"
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:paddingStart="0dp"
    android:paddingEnd="0dp">

    <TextView
        android:id="@+id/quick_timer_notification_title"
        style="@style/TextAppearance.Compat.Notification.Title"
        android:layout_width="match_parent"
        android:layout_height="22dp"
        android:ellipsize="end"
        android:gravity="center_vertical"
        android:singleLine="true" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="24dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/quick_timer_notification_text"
            style="@style/TextAppearance.Compat.Notification.Line2"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:singleLine="true" />

        <TextView
            android:id="@+id/quick_timer_notification_toggle"
            style="@style/TextAppearance.Compat.Notification.Title"
            android:layout_width="40dp"
            android:layout_height="match_parent"
            android:gravity="center"
            android:singleLine="true" />

        <TextView
            android:id="@+id/quick_timer_notification_repeat"
            style="@style/TextAppearance.Compat.Notification.Title"
            android:layout_width="40dp"
            android:layout_height="match_parent"
            android:gravity="center"
            android:singleLine="true" />
    </LinearLayout>
</LinearLayout>
